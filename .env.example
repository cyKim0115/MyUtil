# Copy to `.env` and fill in. Do not commit `.env`.

# Absolute path to the Unity project root to sync FROM
SYNC_SOURCE_ROOT=

# Path under SYNC_SOURCE_ROOT to the util scripts folder (use / separators)
SYNC_SOURCE_SCRIPTS_REL=

# Path under SYNC_SOURCE_ROOT to Cursor config (usually .cursor)
SYNC_SOURCE_CURSOR_REL=.cursor

# Optional: extra source path for SerializableDictionaryDrawer if it lives outside the util Editor folder
# SYNC_SOURCE_EXTRA_DRAWER_REL=
